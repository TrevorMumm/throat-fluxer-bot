FLUXER_BOT_TOKEN=
# Use FLUXER_BOT_TOKEN for Fluxer instances, or DISCORD_BOT_TOKEN for Discord instances.
# The bot token is found under Bot > Token in the respective developer portal.
# This is NOT the Application ID or Public Key — it's the secret token you copy/reset.
COMMAND_PREFIX=!
# This is the command prefix that the bot will listen for. You can change it to any character or string you prefer.
# NOTE: Do not share your bot token with anyone, as it can be used to control your bot. Keep it secure and private.
DATABASE_URL=postgresql://fluxer:fluxer-pw@localhost:5432/fluxer?schema=public
# For Docker-to-Docker usage, use host `postgres` instead of `localhost`.
#
# Postgres init-only values (used only when the volume is created).
# Set these only when initializing a fresh volume, and keep them aligned with
# DATABASE_URL. If the volume is not wiped, these do not need to be set.
# You can pass them via environment when running docker compose instead of
# storing them here.
POSTGRES_USER=fluxer
POSTGRES_PASSWORD=fluxer-pw
POSTGRES_DB=fluxer
# Change POSTGRES_PASSWORD for production deployments.
NODE_ENV= # optional, defaults to 'development' if not set
PREFIX_CACHE_TTL_SECONDS=300 # optional, cache TTL for guild prefixes

# ── API connection (optional — defaults to Fluxer) ──────────────────
# API_BASE_URL=http://localhost:49319/api   # leave empty for Discord
# API_VERSION=1                              # 1 for Fluxer, 10 for Discord
# GATEWAY_VERSION=1                          # 1 for Fluxer, 10 for Discord
# GATEWAY_INTENTS=0                          # 0 for Fluxer, 33281 for Discord

# ── Sync feature (optional) ─────────────────────────────────────────
# INSTANCE_ID=A                              # "A", "B", or "C"
# SYNC_POLL_INTERVAL_MS=3000
#
# Peer instances — set for each peer you want to sync with:
# PEER_B_API_BASE_URL=https://example.com/api
# PEER_B_BOT_TOKEN=<peer-B-bot-token>
# PEER_B_API_VERSION=1
#
# PEER_C_API_BASE_URL=                       # empty for Discord
# PEER_C_BOT_TOKEN=<peer-C-bot-token>
# PEER_C_API_VERSION=10
