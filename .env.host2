# This is a placeholder token. Replace it with your actual bot token from the Fluxer Developer Portal.
COMMAND_PREFIX=!
# This is the command prefix that the bot will listen for. You can change it to any character or string you prefer.
# NOTE: Do not share your bot token with anyone, as it can be used to control your bot. Keep it secure and private.
DATABASE_URL=postgresql://fluxer-bot:q6Bp4Pfq5ffchP6r76UJ@fluxer-postgres:5432/fluxer?schema=public

# For Docker-to-Docker usage, use host `postgres` instead of `localhost`.
#
# Postgres init-only values (used only when the volume is created).
# Set these only when initializing a fresh volume, and keep them aligned with
# DATABASE_URL. If the volume is not wiped, these do not need to be set.
# You can pass them via environment when running docker compose instead of
# storing them here.
POSTGRES_USER=fluxer-bot
POSTGRES_PASSWORD=q6Bp4Pfq5ffchP6r76UJ
POSTGRES_DB=fluxer
# Change POSTGRES_PASSWORD for production deployments.
NODE_ENV= # optional, defaults to 'development' if not set
PREFIX_CACHE_TTL_SECONDS=300 # optional, cache TTL for guild prefixes

# ── Sync feature ──
INSTANCE_ID=B
# Use host.docker.internal or the Docker host IP to reach Host 1's Fluxer API from inside Docker.
# If host.docker.internal doesn't work, replace with the host machine's LAN IP.
PEER_API_BASE_URL=http://host.docker.internal:49319/api
PEER_BOT_TOKEN=1482089134733512722.KIaFUJNHdLtHyG99Nz2xIVPfRIftPUjtFOvv-LKloL0
SYNC_POLL_INTERVAL_MS=3000 # how often to check for sync events (ms)
