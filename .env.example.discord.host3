# ── Instance C — Discord ──────────────────────────────────────────────
# This instance connects to the official Discord API instead of a Fluxer instance.
# Leave API_BASE_URL empty to use the default Discord API (discord.com/api).

API_BASE_URL=
API_VERSION=10
GATEWAY_VERSION=10
# GUILDS (1) | GUILD_MESSAGES (512) | MESSAGE_CONTENT (32768)
GATEWAY_INTENTS=33281

DISCORD_BOT_TOKEN=
# ── Database (shared with Host 1) ───────────────────────────────────
DATABASE_URL=postgresql://fluxer:fluxer-pw@localhost:5432/fluxer?schema=public
POSTGRES_USER=fluxer
POSTGRES_PASSWORD=fluxer-pw
POSTGRES_DB=fluxer

# ── Sync feature ────────────────────────────────────────────────────
INSTANCE_ID=C
SYNC_POLL_INTERVAL_MS=3000

# Peer A — Fluxer instance on Host 1
PEER_A_API_BASE_URL=
PEER_A_BOT_TOKEN=
PEER_A_API_VERSION=1

# Peer B — Fluxer instance on Host 2 (throat.chat)
PEER_B_API_BASE_URL=
PEER_B_BOT_TOKEN=
PEER_B_API_VERSION=1
